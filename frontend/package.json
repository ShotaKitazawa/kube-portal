{
  "name": "kube-portal",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && oxlint .",
    "format": "oxfmt .",
    "openapi-ts": "pnpm exec openapi-typescript ../openapi.yaml -o src/gen/api.d.ts",
    "test": "vitest run --passWithNoTests",
    "sync:pin": "node ../scripts/sync-frontend.ts --pin"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "normalize.css": "^8.0.1",
    "oidc-client-ts": "^3.1.0",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^0.18.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.0.23",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
